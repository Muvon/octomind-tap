#!/usr/bin/env bash
# Publish the latest trained checkpoint to HuggingFace Hub.
#
# Auto-detects the most recent embed-* checkpoint under checkpoints/,
# runs the publish gate (`eval_gate.py`) against the frozen
# data/eval_real.jsonl, and uploads safetensors + ONNX + tokenizer +
# model card if the gate passes.
#
# Reranker upload is intentionally NOT supported here — production has
# confirmed the cross-encoder doesn't help at the current capability
# count. If that changes, restore the previous --rerank-only path.
#
# Usage:
#   HF_TOKEN=hf_... bin/publish                          # bi-encoder, with gate
#   HF_TOKEN=hf_... bin/publish --org muvon              # override namespace
#   HF_TOKEN=hf_... bin/publish --private                # private repo
#   HF_TOKEN=hf_... bin/publish --dry-run                # print, don't upload
#   HF_TOKEN=hf_... bin/publish --force                  # bypass the gate (use sparingly)
#   HF_TOKEN=hf_... bin/publish --skip-gate              # alias for --force
#   HF_TOKEN=hf_... bin/publish --baseline path.json     # custom baseline file
#
# After upload the runtime at octomind/src/embeddings/mod.rs picks up
# the new weights on first launch via hf_hub.

set -euo pipefail

cd "$(dirname "$0")/.."

ORG="muvon"
PRIVATE=""
DRY_RUN=0
FORCE=0
BASELINE_PATH=""

while [ $# -gt 0 ]; do
  case "$1" in
    --embed-only) shift ;; # accepted for compat, embed is the only mode now
    --org)
      ORG="$2"
      shift 2
      ;;
    --private)
      PRIVATE="--private"
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --force | --skip-gate)
      FORCE=1
      shift
      ;;
    --baseline)
      BASELINE_PATH="$2"
      shift 2
      ;;
    *)
      echo "unknown arg: $1" >&2
      exit 2
      ;;
  esac
done

if [ -z "${HF_TOKEN:-}" ] && [ $DRY_RUN -eq 0 ]; then
  echo "error: set HF_TOKEN (read+write scope)" >&2
  exit 1
fi

PY=${PY:-uv run python}

RUN=$(ls -td checkpoints/embed-*/ 2>/dev/null | head -1)
RUN=${RUN%/}
if [ -z "$RUN" ]; then
  echo "no embed-* checkpoint found in checkpoints/" >&2
  exit 1
fi

if [ ! -f "$RUN/model.safetensors" ]; then
  echo "missing model.safetensors in $RUN — is this a trained checkpoint?" >&2
  exit 1
fi

HAS_ONNX=""
[ -d "$RUN/onnx" ] && HAS_ONNX="(includes ONNX)"

# ---------------------------------------------------------------------------
# Publish gate
# ---------------------------------------------------------------------------
#
# Blocks the upload on regression against the recorded baseline at
# eval_baselines.json (or --baseline override). On first ever run there
# is no baseline — the gate is informational, and you should record
# the baseline AFTER promotion with:
#
#   uv run python scripts/eval_gate.py --model <HF id of current shipped> \
#       --write-baseline eval_baselines.json
#
# Skipping the gate is supported for emergencies (--force / --skip-gate)
# but should be the rare exception. Each skipped publish increases the
# odds of a silent regression slipping into production.

if [ $FORCE -eq 1 ]; then
  echo "==> publish gate: SKIPPED (--force)"
else
  if [ -f data/eval_real.jsonl ]; then
    echo "==> publish gate: scoring $RUN on data/eval_real.jsonl"
    GATE_ARGS="--model $RUN"
    if [ -n "$BASELINE_PATH" ]; then
      GATE_ARGS="$GATE_ARGS --baseline $BASELINE_PATH"
    fi
    if ! $PY scripts/eval_gate.py $GATE_ARGS; then
      echo
      echo "Publish blocked by eval_gate."
      echo "Re-run with --force to override (and document why)."
      exit 1
    fi
  else
    echo "==> publish gate: data/eval_real.jsonl missing — gate cannot run"
    echo "    build it once with:  $PY scripts/build_eval_seed.py"
    echo "    aborting; re-run with --force to bypass."
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# Upload
# ---------------------------------------------------------------------------

REPO="$ORG/octomind-embed"
echo
echo "==> upload: $RUN  →  hf.co/$REPO  $HAS_ONNX"

if [ $DRY_RUN -eq 1 ]; then
  echo "    [dry-run] would upload safetensors, config, tokenizer, model card${HAS_ONNX:+, onnx/}"
  exit 0
fi

$PY scripts/push_hf.py --run "$RUN" --repo "$REPO" --type embed $PRIVATE

echo
echo "Done."
echo "  https://huggingface.co/$REPO"
echo
echo "Record the new baseline AFTER you confirm the rollout in production:"
echo "  $PY scripts/eval_gate.py --model $REPO --write-baseline eval_baselines.json"
