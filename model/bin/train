#!/usr/bin/env bash
# Full fine-tuning pipeline: (optional augment) -> build -> train -> eval -> ONNX export.
#
# Usage:
#   bin/train                       # bi-encoder only (default)
#   bin/train --reranker            # reranker only (requires existing dataset)
#   bin/train --all                 # both bi-encoder and reranker
#   bin/train --llm                 # also generate LLM paraphrases first
#   bin/train --llm --resume        # resume an interrupted LLM augmentation run
#   bin/train --skip-build          # reuse existing data/, just train + eval
#   bin/train --skip-export         # skip the ONNX export step
#
# Examples:
#   bin/train --llm --all           # full deep run: augment + train both + export
#   bin/train --reranker            # add reranker after embed already trained
#
# After completion, prints the exact upload commands for both models.

set -euo pipefail

cd "$(dirname "$0")/.."

LLM=0
SKIP_BUILD=0
SKIP_EXPORT=0
RESUME=""
TRAIN_EMBED=1
TRAIN_RERANK=0
REALIGN_NEGS=0

while [ $# -gt 0 ]; do
  case "$1" in
    --llm)
      LLM=1
      shift
      ;;
    --resume)
      RESUME="--resume"
      shift
      ;;
    --skip-build)
      SKIP_BUILD=1
      shift
      ;;
    --skip-export)
      SKIP_EXPORT=1
      shift
      ;;
    --reranker)
      TRAIN_EMBED=0
      TRAIN_RERANK=1
      shift
      ;;
    --all)
      TRAIN_EMBED=1
      TRAIN_RERANK=1
      shift
      ;;
    --realign-negs)
      # Re-mine triplets.jsonl using the most recent FT bi-encoder so the
      # reranker's training negatives match its inference-time competitors.
      # Implies a dataset rebuild even if --skip-build was set; only the
      # triplets path is affected (pairs.jsonl is rewritten with the same
      # content).
      REALIGN_NEGS=1
      shift
      ;;
    *)
      echo "unknown arg: $1" >&2
      exit 2
      ;;
  esac
done

PY=${PY:-uv run python}

if [ $LLM -eq 1 ] && [ $SKIP_BUILD -eq 0 ]; then
  echo "==> augment_llm.py (anthropic)"
  $PY scripts/augment_llm.py $RESUME
fi

BUILD_EXTRA_ARGS=""
if [ $REALIGN_NEGS -eq 1 ]; then
  LATEST_EMBED=$(ls -td checkpoints/embed-*/ 2>/dev/null | head -1)
  LATEST_EMBED=${LATEST_EMBED%/}
  if [ -z "$LATEST_EMBED" ]; then
    echo "--realign-negs needs a fine-tuned bi-encoder in checkpoints/embed-*/ but none was found" >&2
    exit 1
  fi
  echo "==> using fine-tuned bi-encoder for retrieval-aligned negative mining: $LATEST_EMBED"
  BUILD_EXTRA_ARGS="--neg-embed-model $LATEST_EMBED"
fi

if [ $SKIP_BUILD -eq 0 ] || [ $REALIGN_NEGS -eq 1 ]; then
  echo "==> build_dataset.py"
  $PY scripts/build_dataset.py $BUILD_EXTRA_ARGS
fi

if [ $TRAIN_EMBED -eq 1 ]; then
  echo "==> train.py (bi-encoder)"
  $PY scripts/train.py

  RUN=$(ls -td checkpoints/embed-*/ 2>/dev/null | head -1)
  if [ -z "$RUN" ]; then
    RUN=$(ls -td checkpoints/*/ 2>/dev/null | grep -v "rerank-" | head -1)
  fi
  if [ -z "$RUN" ]; then
    echo "no embedding checkpoint found in checkpoints/" >&2
    exit 1
  fi
  RUN=${RUN%/}
  echo "==> embedding checkpoint: $RUN"

  echo
  echo "==> eval base (BAAI/bge-small-en-v1.5)"
  $PY scripts/eval.py --run "$RUN" --base

  echo
  echo "==> eval fine-tuned ($RUN)"
  $PY scripts/eval.py --run "$RUN"

  if [ $SKIP_EXPORT -eq 0 ]; then
    echo
    echo "==> export_onnx.py"
    $PY scripts/export_onnx.py --run "$RUN"
  fi
fi

if [ $TRAIN_RERANK -eq 1 ]; then
  echo "==> train_reranker.py (cross-encoder)"
  $PY scripts/train_reranker.py

  RERANK_RUN=$(ls -td checkpoints/rerank-*/ 2>/dev/null | head -1)
  if [ -z "$RERANK_RUN" ]; then
    echo "no reranker checkpoint found in checkpoints/" >&2
    exit 1
  fi
  RERANK_RUN=${RERANK_RUN%/}
  echo "==> reranker checkpoint: $RERANK_RUN"

  # Pair with the fine-tuned bi-encoder if we have one — that's the actual
  # production pipeline. Falls back to base BGE if no embed checkpoint
  # exists (e.g. user ran `bin/train --reranker` standalone).
  EMBED_FOR_EVAL=$(ls -td checkpoints/embed-*/ 2>/dev/null | head -1)
  EMBED_FOR_EVAL=${EMBED_FOR_EVAL%/}
  if [ -n "$EMBED_FOR_EVAL" ]; then
    EMBED_ARGS="--embed-model $EMBED_FOR_EVAL"
    echo "==> using fine-tuned bi-encoder for rerank eval: $EMBED_FOR_EVAL"
  else
    EMBED_ARGS=""
    echo "==> no fine-tuned bi-encoder found; rerank eval pairs with base BGE"
  fi

  echo
  echo "==> eval reranker base (BAAI/bge-reranker-base)"
  $PY scripts/eval_reranker.py --run "$RERANK_RUN" --base $EMBED_ARGS

  echo
  echo "==> eval reranker fine-tuned ($RERANK_RUN)"
  $PY scripts/eval_reranker.py --run "$RERANK_RUN" $EMBED_ARGS

  if [ $SKIP_EXPORT -eq 0 ]; then
    echo
    echo "==> export_onnx_reranker.py"
    $PY scripts/export_onnx_reranker.py --run "$RERANK_RUN"
  fi
fi

echo
echo "Done."
if [ $TRAIN_EMBED -eq 1 ]; then
  echo "  Upload embedding:  HF_TOKEN=... $PY scripts/push_hf.py --run $RUN --repo muvon/octomind-embed --type embed"
fi
if [ $TRAIN_RERANK -eq 1 ]; then
  echo "  Upload reranker:   HF_TOKEN=... $PY scripts/push_hf.py --run $RERANK_RUN --repo muvon/octomind-rerank --type rerank"
fi
