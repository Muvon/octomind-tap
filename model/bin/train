#!/usr/bin/env bash
# Full fine-tuning pipeline: (optional augment) -> build -> train -> eval -> ONNX export.
#
# Embed-only flow (reranker is intentionally not built — production has
# confirmed it does not help at the current capability count).
#
# Usage:
#   bin/train                          # one-shot bi-encoder run
#   bin/train --llm                    # also generate LLM paraphrases first
#   bin/train --llm --resume           # resume an interrupted LLM augmentation run
#   bin/train --iterations N           # iterative hard-negative re-mining (N rounds)
#   bin/train --skip-build             # reuse existing data/, just train + eval
#   bin/train --skip-export            # skip the ONNX export step
#   bin/train --legacy                 # plain model.fit() loop with MNRL (diagnostic)
#
# Iterative re-mining (recommended for the production run):
#
#   bin/train --llm --iterations 2
#
# Round 1: build with centroid-similarity mining (base BGE-small).
# Round 2+: re-mine triplets using the bi-encoder FT'd in the previous
#           round — negatives now MATCH the FT model's retrieval mistakes
#           at inference time, which is the BGE / NV-Retriever recipe.
# https://bge-model.com/tutorial/7_Finetuning/7.2.1.html
#
# After completion, prints the exact upload command for the embedding model.

set -euo pipefail

cd "$(dirname "$0")/.."

LLM=0
SKIP_BUILD=0
SKIP_EXPORT=0
RESUME=""
ITERATIONS=1
LEGACY_FLAG=""

while [ $# -gt 0 ]; do
  case "$1" in
    --llm)
      LLM=1
      shift
      ;;
    --resume)
      RESUME="--resume"
      shift
      ;;
    --skip-build)
      SKIP_BUILD=1
      shift
      ;;
    --skip-export)
      SKIP_EXPORT=1
      shift
      ;;
    --iterations)
      ITERATIONS="$2"
      shift 2
      ;;
    --legacy)
      LEGACY_FLAG="--legacy"
      shift
      ;;
    *)
      echo "unknown arg: $1" >&2
      exit 2
      ;;
  esac
done

if ! [[ $ITERATIONS =~ ^[0-9]+$ ]] || [ "$ITERATIONS" -lt 1 ]; then
  echo "error: --iterations must be a positive integer" >&2
  exit 2
fi

PY=${PY:-uv run python}

# ---------------------------------------------------------------------------
# Phase 0a: bootstrap the real-user eval set (once, idempotent)
# ---------------------------------------------------------------------------

if [ ! -f data/eval_real.jsonl ]; then
  echo "==> build_eval_seed.py (first run — no data/eval_real.jsonl yet)"
  $PY scripts/build_eval_seed.py
fi

# ---------------------------------------------------------------------------
# Phase 0b: LLM paraphrase augmentation (optional, once)
# ---------------------------------------------------------------------------

if [ $LLM -eq 1 ] && [ $SKIP_BUILD -eq 0 ]; then
  echo "==> augment_llm.py (anthropic)"
  $PY scripts/augment_llm.py $RESUME
fi

# ---------------------------------------------------------------------------
# Phase 1: build dataset (round 1 uses centroid mining — no FT model yet)
# ---------------------------------------------------------------------------

if [ $SKIP_BUILD -eq 0 ]; then
  echo "==> build_dataset.py (round 1: centroid hard-neg mining)"
  $PY scripts/build_dataset.py
fi

# ---------------------------------------------------------------------------
# Phase 2: iterative train + re-mine
# ---------------------------------------------------------------------------
#
# In a single-iteration run this is just "train once". With
# --iterations N, each round trains a new checkpoint, then rebuilds
# triplets.jsonl using that checkpoint's retrieval mistakes as the
# hard-negative source. The bi-encoder's training and inference
# distributions converge over rounds — typically 2 rounds is the
# sweet spot; 3+ shows diminishing returns and risks overfitting on
# the specific holdout.

LAST_RUN=""
for ((i = 1; i <= ITERATIONS; i++)); do
  echo
  echo "================================================================"
  echo "  iteration $i / $ITERATIONS"
  echo "================================================================"

  if [ $i -gt 1 ]; then
    # Rebuild triplets only — pairs.jsonl/holdout.jsonl are unchanged.
    # The --neg-embed-model flag tells build_dataset.py to use the
    # PREVIOUS round's FT bi-encoder for retrieval-based mining.
    echo "==> rebuild triplets (round $i: retrieval-aligned mining with $LAST_RUN)"
    $PY scripts/build_dataset.py --neg-embed-model "$LAST_RUN"
  fi

  echo "==> train.py (bi-encoder, iter $i)"
  $PY scripts/train.py $LEGACY_FLAG

  RUN=$(ls -td checkpoints/embed-*/ 2>/dev/null | head -1)
  RUN=${RUN%/}
  if [ -z "$RUN" ]; then
    echo "no embedding checkpoint found in checkpoints/" >&2
    exit 1
  fi
  echo "==> checkpoint: $RUN"
  LAST_RUN="$RUN"
done

# ---------------------------------------------------------------------------
# Phase 3: evaluate
# ---------------------------------------------------------------------------

echo
echo "==> eval base (BAAI/bge-small-en-v1.5) — for comparison"
$PY scripts/eval.py --run "$LAST_RUN" --base

echo
echo "==> eval fine-tuned ($LAST_RUN) — holdout distribution"
$PY scripts/eval.py --run "$LAST_RUN"

# Real-user eval (the production gate). Only runs if the eval set
# exists — otherwise nudges the user to build it.
if [ -f data/eval_real.jsonl ]; then
  echo
  echo "==> eval_gate.py — real-user distribution (publish gate)"
  # Informational only here (no --baseline written); bin/publish enforces.
  $PY scripts/eval_gate.py --model "$LAST_RUN" || true
else
  echo
  echo "==> eval_real.jsonl missing — skipping real-user eval"
  echo "    build it once with:  $PY scripts/build_eval_seed.py"
fi

# ---------------------------------------------------------------------------
# Phase 4: ONNX export
# ---------------------------------------------------------------------------

if [ $SKIP_EXPORT -eq 0 ]; then
  echo
  echo "==> export_onnx.py"
  $PY scripts/export_onnx.py --run "$LAST_RUN"
fi

echo
echo "Done."
echo "  Upload:        HF_TOKEN=... bin/publish --embed-only"
echo "  Calibrate τ/δ: $PY scripts/calibrate_thresholds.py --model $LAST_RUN"
